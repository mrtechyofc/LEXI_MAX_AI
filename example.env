# =============================================================================
# LEXI — Environment configuration
# -----------------------------------------------------------------------------
# Location: project root  →  lexi/example.env
# Usage:    cp example.env .env  and edit values before starting the stack.
#
# Every variable below is consumed by either:
#   • backend/config/settings.py     (Pydantic Settings — strongly typed)
#   • backend/tools/*                (os.getenv calls for SMTP, etc.)
#   • docker-compose.yml             (env_file: .env)
#   • frontend (NEXT_PUBLIC_* only)
# =============================================================================


# -----------------------------------------------------------------------------
# 1. CORE APPLICATION
# -----------------------------------------------------------------------------
LEXI_ENV=development                # development | staging | production
LEXI_LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
LEXI_SECRET_KEY=change-me-to-a-long-random-string-min-32-bytes
LEXI_JWT_ALGORITHM=HS256
LEXI_JWT_EXPIRE_MINUTES=1440        # 24 hours
LEXI_DATA_ROOT=./data               # Sandbox root for file tools (read/write jail)

# CORS — comma-free JSON array. The frontend origin(s) allowed to call the API.
# Pydantic parses this as a list when wrapped in []. For multiple, use JSON.
CORS_ORIGINS=["http://localhost:3000"]


# -----------------------------------------------------------------------------
# 2. LLM PROVIDERS
# -----------------------------------------------------------------------------
# Pick ONE active provider via DEFAULT_LLM_PROVIDER. The others can stay empty.
# If no keys are set at all, LEXI falls back to a deterministic dev-LLM stub
# so the app still boots and is fully testable offline.

DEFAULT_LLM_PROVIDER=openai         # openai | anthropic | gemini | ollama
DEFAULT_LLM_MODEL=gpt-4o-mini

# OpenAI
OPENAI_API_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# Google (Gemini)
GOOGLE_API_KEY=

# Ollama (local models). Default points at the host machine.
OLLAMA_BASE_URL=http://localhost:11434


# -----------------------------------------------------------------------------
# 3. DATABASES
# -----------------------------------------------------------------------------
# Postgres (production) — used by docker-compose to create the DB
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=lexi
POSTGRES_USER=lexi
POSTGRES_PASSWORD=lexi

# SQLAlchemy DSN. For local dev without docker, use SQLite:
#   DATABASE_URL=sqlite+aiosqlite:///./data/lexi.db
DATABASE_URL=postgresql+asyncpg://lexi:lexi@postgres:5432/lexi


# -----------------------------------------------------------------------------
# 4. REDIS  /  CELERY
# -----------------------------------------------------------------------------
# DB 0 → general cache + short-term memory
# DB 1 → Celery broker
# DB 2 → Celery result backend
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2


# -----------------------------------------------------------------------------
# 5. VECTOR STORE  (long-term semantic memory)
# -----------------------------------------------------------------------------
VECTOR_BACKEND=chromadb             # chromadb | faiss
CHROMA_PERSIST_DIR=./data/chroma
FAISS_PERSIST_DIR=./data/faiss

# Embeddings — used by backend/memory/embeddings.py.
# When OPENAI_API_KEY is unset, a deterministic offline embedder is used.
EMBEDDING_MODEL=text-embedding-3-small


# -----------------------------------------------------------------------------
# 6. VOICE PIPELINE
# -----------------------------------------------------------------------------
# STT — choose local Whisper (CPU/GPU) or the OpenAI Whisper API
STT_BACKEND=whisper                 # whisper | openai-whisper-api
WHISPER_MODEL=base                  # tiny | base | small | medium | large

# TTS — Coqui is local & free; ElevenLabs/OpenAI are cloud
TTS_BACKEND=coqui                   # coqui | elevenlabs | openai
ELEVENLABS_API_KEY=

# Wake-word phrase used by backend/voice/wakeword.py
WAKE_WORD=hey lexi

# Optional: Porcupine wake-word detector access key (read by os.getenv)
PORCUPINE_ACCESS_KEY=


# -----------------------------------------------------------------------------
# 7. VISION
# -----------------------------------------------------------------------------
VISION_PROVIDER=openai              # which multimodal LLM image_analyzer.py uses


# -----------------------------------------------------------------------------
# 8. EMAIL TOOL  (optional — only needed if the agent will send emails)
# -----------------------------------------------------------------------------
# Consumed by backend/tools/automation/email.py via os.getenv.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=


# -----------------------------------------------------------------------------
# 9. OBSERVABILITY
# -----------------------------------------------------------------------------
PROMETHEUS_ENABLED=true
# Set to an OTLP gRPC endpoint to enable distributed tracing (Jaeger/Tempo)
OTEL_EXPORTER_OTLP_ENDPOINT=


# -----------------------------------------------------------------------------
# 10. FRONTEND  (Next.js)
# -----------------------------------------------------------------------------
# Only NEXT_PUBLIC_* variables are exposed to the browser bundle.
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
